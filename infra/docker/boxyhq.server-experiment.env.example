NEXTAUTH_URL=http://account.glyph-beta.test
APP_URL=http://account.glyph-beta.test
NEXTAUTH_SECRET=
NEXTAUTH_SESSION_STRATEGY=database
NEXTAUTH_COOKIE_DOMAIN=.glyph-beta.test

AUTH_PROVIDERS=credentials
HIDE_LANDING_PAGE=true
CONFIRM_EMAIL=false
DISABLE_NON_BUSINESS_EMAIL_SIGNUP=false

DATABASE_URL=postgresql://boxyhq:change-me@boxyhq-postgres:5432/boxyhq?schema=public
BOXYHQ_POSTGRES_DB=boxyhq
BOXYHQ_POSTGRES_USER=boxyhq
BOXYHQ_POSTGRES_PASSWORD=change-me
BOXYHQ_POSTGRES_HOST_PATH=/var/lib/boxyhq/postgres
BOXYHQ_APP_PORT=4002

GLYPH_SHARED_DOCKER_NETWORK=glyph-experiment

FEATURE_TEAM_PAYMENTS=false
FEATURE_TEAM_SSO=true
FEATURE_TEAM_DSYNC=true
FEATURE_TEAM_AUDIT_LOG=true
FEATURE_TEAM_WEBHOOK=true
FEATURE_TEAM_API_KEY=true
FEATURE_TEAM_DELETION=true
